---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/blog/Headline.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

export const prerender = true;

const metadata = { title: '标签' };
const posts = await fetchPosts();

const tagMap = new Map<string, { slug: string; title: string; count: number }>();
posts.forEach((post) => {
  post.tags?.forEach((tag) => {
    if (tagMap.has(tag.slug)) {
      tagMap.get(tag.slug)!.count++;
    } else {
      tagMap.set(tag.slug, { ...tag, count: 1 });
    }
  });
});

const tags = [...tagMap.values()].sort((a, b) => b.count - a.count);
const maxCount = Math.max(...tags.map((t) => t.count), 1);

function getSizeClass(count: number): string {
  const ratio = count / maxCount;
  if (ratio > 0.8) return 'text-2xl font-bold';
  if (ratio > 0.6) return 'text-xl font-semibold';
  if (ratio > 0.4) return 'text-lg font-medium';
  if (ratio > 0.2) return 'text-base';
  return 'text-sm';
}
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline subtitle={`共 ${tags.length} 个标签`}>标签</Headline>

    <div class="flex flex-wrap gap-3 justify-center">
      {
        tags.map((tag) => (
          <a
            href={getPermalink(tag.slug, 'tag')}
            class:list={[
              'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg transition-colors',
              'bg-gray-100 dark:bg-slate-700 hover:bg-primary/10 dark:hover:bg-blue-400/20',
              'text-muted dark:text-slate-300 hover:text-primary dark:hover:text-blue-400',
              getSizeClass(tag.count),
            ]}
          >
            {tag.title}
            <span class="text-xs opacity-60">({tag.count})</span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
