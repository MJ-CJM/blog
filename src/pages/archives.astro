---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/blog/Headline.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

export const prerender = true;

const metadata = { title: '归档' };
const posts = await fetchPosts();

const postsByYear = new Map<number, typeof posts>();
posts.forEach((post) => {
  const year = post.publishDate.getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
});

const sortedYears = [...postsByYear.keys()].sort((a, b) => b - a);
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline subtitle={`共 ${posts.length} 篇文章`}>归档</Headline>

    {
      sortedYears.map((year) => (
        <div class="mb-12">
          <h2 class="text-3xl font-bold font-heading mb-6 dark:text-slate-200">{year}</h2>
          <div class="border-l-2 border-primary dark:border-blue-400 ml-2 pl-6 space-y-4">
            {postsByYear.get(year)!.map((post) => {
              const month = String(post.publishDate.getMonth() + 1).padStart(2, '0');
              const day = String(post.publishDate.getDate()).padStart(2, '0');
              return (
                <div class="relative flex items-baseline gap-4">
                  <div class="absolute -left-[31px] top-2 w-3 h-3 rounded-full bg-primary dark:bg-blue-400" />
                  <span class="text-sm text-muted dark:text-slate-400 font-mono whitespace-nowrap">
                    {month}-{day}
                  </span>
                  <a
                    href={getPermalink(post.permalink, 'post')}
                    class="text-default dark:text-slate-200 hover:text-primary dark:hover:text-blue-400 transition-colors"
                  >
                    {post.title}
                  </a>
                </div>
              );
            })}
          </div>
        </div>
      ))
    }
  </section>
</Layout>
