---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/blog/Headline.astro';
import { friendLinks } from '~/data/links';

export const prerender = true;

const metadata = { title: '友情链接' };
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline subtitle="互联网上的朋友们">友情链接</Headline>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        friendLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener"
            class="group flex items-center gap-4 p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-primary dark:hover:border-blue-400 hover:shadow-lg transition-all"
          >
            <img
              src={link.avatar}
              alt={link.name}
              class="w-14 h-14 rounded-full object-cover flex-shrink-0"
              loading="lazy"
            />
            <div class="min-w-0">
              <h3 class="font-bold text-default dark:text-slate-200 group-hover:text-primary dark:group-hover:text-blue-400 transition-colors truncate">
                {link.name}
              </h3>
              <p class="text-sm text-muted dark:text-slate-400 line-clamp-2">
                {link.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
