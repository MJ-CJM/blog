---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/blog/Headline.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

export const prerender = true;

const metadata = { title: '分类' };
const posts = await fetchPosts();

const categoryMap = new Map<string, { slug: string; title: string; count: number }>();
posts.forEach((post) => {
  if (post.category?.slug) {
    if (categoryMap.has(post.category.slug)) {
      categoryMap.get(post.category.slug)!.count++;
    } else {
      categoryMap.set(post.category.slug, { ...post.category, count: 1 });
    }
  }
});

const categories = [...categoryMap.values()].sort((a, b) => b.count - a.count);
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline subtitle={`共 ${categories.length} 个分类`}>分类</Headline>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        categories.map((cat) => (
          <a
            href={getPermalink(cat.slug, 'category')}
            class="group block p-6 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-primary dark:hover:border-blue-400 hover:shadow-lg transition-all"
          >
            <h3 class="text-xl font-bold font-heading mb-2 text-default dark:text-slate-200 group-hover:text-primary dark:group-hover:text-blue-400 transition-colors">
              {cat.title}
            </h3>
            <p class="text-muted dark:text-slate-400">
              {cat.count} 篇文章
            </p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
